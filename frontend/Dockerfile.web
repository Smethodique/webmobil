# Build stage - Flutter web app  
FROM ubuntu:jammy-20240427 AS builder

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl git unzip xz-utils zip libglu1-mesa \
    && rm -rf /var/lib/apt/lists/*

# Install Flutter via git (shallow clone of stable branch)
ENV FLUTTER_HOME=/opt/flutter
ENV PATH=$FLUTTER_HOME/bin:$PATH
RUN git clone https://github.com/flutter/flutter.git \
    -b stable --depth 1 $FLUTTER_HOME \
    && flutter config --no-analytics \
    && dart --version

WORKDIR /app

COPY . .
RUN flutter pub get

ARG API_BASE_URL=https://webmobil.onrender.com/api/v1
RUN echo "API_BASE_URL=$API_BASE_URL" > .env

RUN flutter build web --release

FROM nginx:alpine
COPY --from=builder /app/build/web /usr/share/nginx/html
COPY nginx.conf /etc/nginx/templates/default.conf.template

EXPOSE 3000
CMD ["/bin/sh", "-c", "envsubst '${PORT}' < /etc/nginx/templates/default.conf.template > /etc/nginx/conf.d/default.conf && nginx -g 'daemon off;'"]
